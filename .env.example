# ============================================================
# 论文复现助手 — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际值

# -----------------------------------------------------------
# LLM 提供商 (必填其一)
# -----------------------------------------------------------
# 支持: deepseek / zhipu
# 使用 LLM_API_KEY 可通用于任意提供商
# 也可以使用提供商专属的 key: DEEPSEEK_API_KEY / ZHIPU_API_KEY

LLM_PROVIDER=deepseek
LLM_API_KEY=your_api_key_here

# DeepSeek（用 deepseek-v4-pro 模型）
# DEEPSEEK_API_KEY=sk-your_deepseek_key_here
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-v4-pro

# Zhipu AI（用 glm-4-plus 模型）
# ZHIPU_API_KEY=your_zhipu_key_here
# LLM_PROVIDER=zhipu
# LLM_MODEL=glm-4-plus

# -----------------------------------------------------------
# LLM 通用配置
# -----------------------------------------------------------
# LLM_MODEL          — 默认值因提供商而异:
#                       deepseek → deepseek-chat (可选: deepseek-reasoner, deepseek-v4-pro)
#                       zhipu    → glm-4-plus     (可选: glm-4-flash, glm-4, glm-3-turbo)
# LLM_MAX_TOKENS     — 默认 65536
# LLM_TEMPERATURE    — 默认 0.7
# LLM_BASE_URL       — 默认值因提供商而异，一般不需要手动设置
#                       deepseek → https://api.deepseek.com/v1/chat/completions
#                       zhipu    → https://open.bigmodel.cn/api/paas/v4/chat/completions

LLM_MAX_TOKENS=65536
LLM_TEMPERATURE=0.7
# LLM_BASE_URL=https://api.deepseek.com/v1/chat/completions

# -----------------------------------------------------------
# Agent 配置
# -----------------------------------------------------------
AGENT_MAX_STEPS=10
AGENT_MAX_RETRIES=3
AGENT_REPLAN_THRESHOLD=3
AGENT_ENABLE_REFLECTION=true
AGENT_ENABLE_MEMORY=true

# -----------------------------------------------------------
# 工作区 & 环境
# -----------------------------------------------------------
# Pip 镜像（国内加速）
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# 工作区配置
WORKSPACE_DIR=./workspace

# Python 解释器（可选，用于兼容旧版包）
# PYTHON_EXECUTABLE=/usr/bin/python3.7

# GitHub 认证（可选，用于克隆私有仓库或避免 API 限流）
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# -----------------------------------------------------------
# 日志配置
# -----------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_RETENTION=7 days
