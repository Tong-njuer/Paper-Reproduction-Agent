# ============================================================
# Environment Variables Configuration
# ============================================================
# Copy this file to .env and fill in your values
#
# Required for full functionality:
#   ZHIPU_API_KEY - Your Zhipu AI API key
#
# Optional overrides:
#   LLM_MODEL - Model to use (default: glm-4)
#   LLM_MAX_TOKENS - Max tokens in response (default: 4096)
#   LLM_TEMPERATURE - Sampling temperature (default: 0.7)
#
# Agent configuration:
#   AGENT_MAX_STEPS - Max steps before termination (default: 50)
#   AGENT_MAX_RETRIES - Max retry attempts (default: 3)
#   AGENT_REPLAN_THRESHOLD - Failures before replanning (default: 3)
#   AGENT_ENABLE_REFLEXION - Enable self-reflection (default: true)
#   AGENT_ENABLE_MEMORY - Enable memory system (default: true)
#
# Memory configuration:
#   MEMORY_DIR - Directory for memory storage (default: ./data/memory)
#   MEMORY_LONG_TERM_ENABLED - Enable long-term memory (default: true)
#
# Logging:
#   LOG_LEVEL - Log level (default: INFO)
#   LOG_DIR - Log directory (default: ./data/logs)
#   LOG_CONSOLE - Enable console output (default: true)
# ============================================================

# Required - Zhipu AI API Key
ZHIPU_API_KEY=your_zhipu_api_key_here

# LLM Configuration
LLM_PROVIDER=zhipu
LLM_MODEL=glm-5.1
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# Agent Configuration
AGENT_MAX_STEPS=50
AGENT_MAX_RETRIES=3
AGENT_REPLAN_THRESHOLD=3
AGENT_ENABLE_REFLEXION=true
AGENT_ENABLE_MEMORY=true

# Memory Configuration
MEMORY_DIR=./data/memory
MEMORY_SHORT_TERM_MAX=10
MEMORY_LONG_TERM_ENABLED=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_DIR=./data/logs
LOG_CONSOLE=true
