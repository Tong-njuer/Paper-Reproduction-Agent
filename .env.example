# ============================================================
# 论文复现助手 — 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际值

# 必填 - Zhipu AI API Key
ZHIPU_API_KEY=your_zhipu_api_key_here

# LLM 配置
LLM_PROVIDER=zhipu
LLM_MODEL=glm-4-plus
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# Agent 配置
AGENT_MAX_STEPS=10
AGENT_MAX_RETRIES=3
AGENT_REPLAN_THRESHOLD=3
AGENT_ENABLE_REFLECTION=true
AGENT_ENABLE_MEMORY=true

# 工作区配置
WORKSPACE_DIR=./workspace

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_RETENTION=7 days
