# ============================================================
# 编程教练 Agent 系统 - 环境配置示例
# ============================================================
# 复制此文件为 .env 并填写实际值

# ---- LLM 配置 ----
# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4

# 或使用 Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-xxx

# 或使用阿里云通义千问
# DASHSCOPE_API_KEY=xxx

# ---- 执行环境配置 ----
# Docker容器配置
DOCKER_IMAGE=python:3.11-slim
DOCKER_TIMEOUT=30

# ---- 服务配置 ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- 日志配置 ----
LOG_LEVEL=INFO
LOG_TRACE_DIR=./logs/traces

# ---- 数据库配置（可选）----
# DATABASE_URL=sqlite:///./data/coach.db
